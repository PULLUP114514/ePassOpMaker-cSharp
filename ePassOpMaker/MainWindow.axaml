<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:media="clr-namespace:Avalonia.Media;assembly=Avalonia.Base"
		mc:Ignorable="d"
		d:DesignWidth="800"
		d:DesignHeight="450"
		x:Class="ePassOpMaker.MainWindow"
		Title="ePass Operators Resources Editor">
		<Grid>
				<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition/>
						<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>
				<Grid Grid.Column="0">
						<Grid.RowDefinitions>
								<RowDefinition/>
								<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>
						<StackPanel Grid.Row="0">
								<Button
								Name="Button_PageSelectorEdit"
								Click="Button_PageSelectorEdit_Click"
								Margin="6"
								Padding="15">
										<Image Name="Image_PageSelectorEdit"
											   Source="avares://ePassOpMaker/Assets/light/edit.png"
											   Width="20">
												<Image.RenderTransform>
														<ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
												</Image.RenderTransform>
										</Image>
								</Button>
								<Button
								Name="Button_PageSelectorFlash"
								Margin="6"
								Padding="15"
								Click="Button_PageSelectorFlash_Click">
										<Image Name="Image_PageSelectorFlash"
											   Source="avares://ePassOpMaker/Assets/light/flash.png"
											   Width="20">
												<Image.RenderTransform>
														<ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
												</Image.RenderTransform>
										</Image>
								</Button>
						</StackPanel>
						<Button Grid.Row="1"
								Name="Button_PageSelectorSettings"
								Click="Button_PageSelectorSettings_Click"
								Margin="6"
								Padding="15">
								<Image Name="Image_PageSelectorSettings"
									   Source="avares://ePassOpMaker/Assets/light/settings.png"
									   Width="20">
										<Image.RenderTransform>
												<ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
										</Image.RenderTransform>
								</Image>
						</Button>

				</Grid>
				<ContentControl Grid.Column="1" x:Name="Content_Main"/>
		</Grid>
</Window>
